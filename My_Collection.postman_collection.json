      "name": "access_token",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var CryptoJS = require('crypto-js');\r",
              " \r",
              "const bmUsername = pm.environment.get('bm_username');\r",
              "const bmPassword = pm.environment.get('bm_password');\r",
              "const ocapiClientPassw = pm.environment.get('ocapi-client-password');\r",
              " \r",
              "const rawStr = CryptoJS.enc.Utf8.parse(`${bmUsername}:${bmPassword}:${ocapiClientPassw}`);\r",
              "const base64Encoded = CryptoJS.enc.Base64.stringify(rawStr);\r",
              " \r",
              "pm.environment.set('USER_CREDENTIALS', base64Encoded);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              " \r",
              "pm.test('Access_token exists', function() {\r",
              "    pm.expect(jsonData.access_token).to.be.a('string');\r",
              "});\r",
              " \r",
              "if (pm.response.code === 200 || pm.response.code === 201) {\r",
              "    pm.environment.set('ACCESS_TOKEN', jsonData.access_token);\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
